{
  "id": "vercel-manifest",
  "version": "0.2.0",
  "displayName": "Vercel",
  "description": "VERIFIED LIVE: Vercel via your logged-in vercel.com session (session bridge — no token). A broad read surface over the same-origin vercel.com/api: account, teams, projects, deployments, domains, aliases and the account activity log. Tested live by Claude Code against a logged-in account — every endpoint below returned 200 JSON.",
  "iconColor": "bg-gray-900 text-white",
  "category": "development",
  "hosts": [
    "https://vercel.com/*"
  ],
  "baseUrl": "https://vercel.com",
  "auth": {
    "type": "cookie"
  },
  "credentialFields": [],
  "tools": [
    {
      "name": "vercel_user",
      "description": "Your Vercel account (id, email, username, plan). VERIFIED.",
      "method": "GET",
      "path": "/api/v2/user",
      "responseType": "json"
    },
    {
      "name": "vercel_teams",
      "description": "Teams you belong to. VERIFIED.",
      "method": "GET",
      "path": "/api/v2/teams",
      "responseType": "json",
      "params": [
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 20
        }
      ]
    },
    {
      "name": "vercel_projects",
      "description": "Your projects. Pass teamId to scope to a team. VERIFIED.",
      "method": "GET",
      "path": "/api/v9/projects",
      "responseType": "json",
      "params": [
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 20
        },
        {
          "name": "teamId",
          "in": "query",
          "type": "string"
        }
      ]
    },
    {
      "name": "vercel_deployments",
      "description": "Recent deployments. Pass projectId/teamId to scope. VERIFIED.",
      "method": "GET",
      "path": "/api/v6/deployments",
      "responseType": "json",
      "params": [
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 20
        },
        {
          "name": "projectId",
          "in": "query",
          "type": "string"
        },
        {
          "name": "teamId",
          "in": "query",
          "type": "string"
        }
      ]
    },
    {
      "name": "vercel_domains",
      "description": "Domains in your account/team. VERIFIED.",
      "method": "GET",
      "path": "/api/v5/domains",
      "responseType": "json",
      "params": [
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 20
        },
        {
          "name": "teamId",
          "in": "query",
          "type": "string"
        }
      ]
    },
    {
      "name": "vercel_aliases",
      "description": "Deployment aliases (custom URLs). VERIFIED.",
      "method": "GET",
      "path": "/api/v1/aliases",
      "responseType": "json",
      "params": [
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 20
        },
        {
          "name": "teamId",
          "in": "query",
          "type": "string"
        }
      ]
    },
    {
      "name": "vercel_events",
      "description": "Your account activity / audit log. VERIFIED.",
      "method": "GET",
      "path": "/api/v3/events",
      "responseType": "json",
      "params": [
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 20
        },
        {
          "name": "teamId",
          "in": "query",
          "type": "string"
        }
      ]
    }
  ],
  "transport": {
    "preferred": "cs"
  },
  "retry": {
    "maxAttempts": 3,
    "respectRetryAfter": true
  },
  "timeoutMs": 30000,
  "trustLevel": "verified",
  "signature": {
    "algorithm": "RSASSA-PKCS1-v1_5-SHA-256",
    "keyId": "lingphi-official-2026",
    "value": ""
  }
}
