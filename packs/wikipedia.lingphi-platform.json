{
  "id": "wikipedia-manifest",
  "version": "0.1.0",
  "displayName": "Wikipedia",
  "description": "VERIFIED LIVE: Wikipedia (English) via the public MediaWiki action API — full-text search, article intro extracts, and your account info (if logged in, via session cookie). No token needed. Tested live by Claude Code: search, extracts and userinfo all returned 200 with real data.",
  "iconColor": "bg-gray-100 text-gray-800",
  "category": "knowledge",
  "hosts": [
    "https://en.wikipedia.org/*"
  ],
  "baseUrl": "https://en.wikipedia.org",
  "auth": {
    "type": "cookie"
  },
  "credentialFields": [],
  "tools": [
    {
      "name": "wikipedia_search",
      "description": "Full-text search English Wikipedia. VERIFIED.",
      "method": "GET",
      "path": "/w/api.php",
      "responseType": "json",
      "params": [
        { "name": "action", "in": "query", "type": "string", "required": true, "default": "query", "description": "Fixed." },
        { "name": "list", "in": "query", "type": "string", "required": true, "default": "search", "description": "Fixed." },
        { "name": "format", "in": "query", "type": "string", "required": true, "default": "json", "description": "Fixed." },
        { "name": "srsearch", "in": "query", "type": "string", "required": true },
        { "name": "srlimit", "in": "query", "type": "number", "default": 5 }
      ]
    },
    {
      "name": "wikipedia_extract",
      "description": "Plain-text intro extract of an article by title. VERIFIED.",
      "method": "GET",
      "path": "/w/api.php",
      "responseType": "json",
      "params": [
        { "name": "action", "in": "query", "type": "string", "required": true, "default": "query", "description": "Fixed." },
        { "name": "prop", "in": "query", "type": "string", "required": true, "default": "extracts", "description": "Fixed." },
        { "name": "exintro", "in": "query", "type": "number", "required": true, "default": 1, "description": "Fixed." },
        { "name": "explaintext", "in": "query", "type": "number", "required": true, "default": 1, "description": "Fixed." },
        { "name": "format", "in": "query", "type": "string", "required": true, "default": "json", "description": "Fixed." },
        { "name": "titles", "in": "query", "type": "string", "required": true }
      ]
    },
    {
      "name": "wikipedia_userinfo",
      "description": "The account info for the current session (anonymous IP if not logged in). VERIFIED.",
      "method": "GET",
      "path": "/w/api.php",
      "responseType": "json",
      "params": [
        { "name": "action", "in": "query", "type": "string", "required": true, "default": "query", "description": "Fixed." },
        { "name": "meta", "in": "query", "type": "string", "required": true, "default": "userinfo", "description": "Fixed." },
        { "name": "format", "in": "query", "type": "string", "required": true, "default": "json", "description": "Fixed." }
      ]
    }
  ],
  "transport": {
    "preferred": "cs"
  },
  "retry": {
    "maxAttempts": 3,
    "respectRetryAfter": true
  },
  "timeoutMs": 30000
}
