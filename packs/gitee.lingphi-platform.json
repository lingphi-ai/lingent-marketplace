{
  "id": "gitee-manifest",
  "version": "0.1.0",
  "displayName": "Gitee",
  "description": "DRAFT (UNSIGNED): Gitee repositories, issues, and pull requests via the session cookie of an open Gitee tab (session bridge). No API token needed once you are logged in. Endpoints below mirror Gitee's public REST API (/api/v5) and are best-effort placeholders — verify each one with scaffold-platform against your logged-in session before signing.",
  "iconColor": "bg-red-100 text-red-700",
  "category": "development",
  "hosts": [
    "https://gitee.com/*"
  ],
  "baseUrl": "https://gitee.com/api/v5",
  "auth": {
    "type": "cookie"
  },
  "credentialFields": [],
  "tools": [
    {
      "name": "gitee_search_repos",
      "description": "Search public repositories on Gitee by keyword. TODO: verify path/params via scaffold-platform.",
      "method": "GET",
      "path": "/search/repositories",
      "params": [
        {
          "name": "q",
          "in": "query",
          "type": "string",
          "required": true,
          "description": "Search keywords, e.g. 'vue admin'."
        },
        {
          "name": "sort",
          "in": "query",
          "type": "string",
          "default": "stars_count",
          "description": "TODO: verify allowed sort values."
        },
        {
          "name": "order",
          "in": "query",
          "type": "string",
          "default": "desc"
        },
        {
          "name": "per_page",
          "in": "query",
          "type": "number",
          "default": 20
        }
      ],
      "responseType": "json"
    },
    {
      "name": "gitee_list_my_issues",
      "description": "List issues assigned to or created by the authenticated user across all repos. TODO: verify path/params via scaffold-platform.",
      "method": "GET",
      "path": "/user/issues",
      "params": [
        {
          "name": "filter",
          "in": "query",
          "type": "string",
          "default": "assigned",
          "description": "TODO: verify — typically assigned | created | all."
        },
        {
          "name": "state",
          "in": "query",
          "type": "string",
          "default": "open"
        },
        {
          "name": "sort",
          "in": "query",
          "type": "string",
          "default": "created"
        },
        {
          "name": "per_page",
          "in": "query",
          "type": "number",
          "default": 20
        }
      ],
      "responseType": "json"
    },
    {
      "name": "gitee_get_repo_issue",
      "description": "Fetch a single issue in a repo by its number. TODO: verify path/params via scaffold-platform.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/issues/{number}",
      "params": [
        {
          "name": "owner",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Repo owner namespace (user or org)."
        },
        {
          "name": "repo",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Repository path/name."
        },
        {
          "name": "number",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Issue number (Gitee issue ids may be alphanumeric, e.g. I1ABCD)."
        }
      ],
      "responseType": "json"
    },
    {
      "name": "gitee_list_repo_pulls",
      "description": "List pull requests in a repository. TODO: verify path/params via scaffold-platform.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/pulls",
      "params": [
        {
          "name": "owner",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Repo owner namespace (user or org)."
        },
        {
          "name": "repo",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Repository path/name."
        },
        {
          "name": "state",
          "in": "query",
          "type": "string",
          "default": "open",
          "description": "TODO: verify — typically open | closed | merged | all."
        },
        {
          "name": "sort",
          "in": "query",
          "type": "string",
          "default": "created"
        },
        {
          "name": "per_page",
          "in": "query",
          "type": "number",
          "default": 20
        }
      ],
      "responseType": "json"
    },
    {
      "name": "gitee_get_pull_diff",
      "description": "Fetch the unified diff / file list for a pull request. TODO: verify path (Gitee may expose this as /pulls/{number}/files) via scaffold-platform.",
      "method": "GET",
      "path": "/repos/{owner}/{repo}/pulls/{number}/files",
      "params": [
        {
          "name": "owner",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "repo",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "number",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Pull request number."
        }
      ],
      "responseType": "json"
    },
    {
      "name": "gitee_create_issue_comment",
      "description": "Post a comment on an issue. WRITE action — requires approval. TODO: verify path/body via scaffold-platform; cookie-session writes may need a CSRF header (add auth.csrf).",
      "method": "POST",
      "path": "/repos/{owner}/{repo}/issues/{number}/comments",
      "params": [
        {
          "name": "owner",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "repo",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "number",
          "in": "path",
          "type": "string",
          "required": true,
          "description": "Issue number."
        },
        {
          "name": "body",
          "in": "body",
          "type": "string",
          "required": true,
          "description": "Comment text."
        }
      ],
      "responseType": "json",
      "requiresApproval": true
    }
  ],
  "retry": {
    "maxAttempts": 3,
    "respectRetryAfter": true
  },
  "timeoutMs": 30000,
  "transport": {
    "preferred": "cs"
  }
}
