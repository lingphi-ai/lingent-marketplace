    },
    {
      "name": "snow_problems",
      "description": "Problem records. VERIFIED.",
      "method": "GET",
      "path": "/api/now/table/problem",
      "responseType": "json",
      "params": [
        {
          "name": "sysparm_query",
          "in": "query",
