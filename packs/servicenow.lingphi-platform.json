{
  "id": "servicenow-manifest",
  "version": "0.2.0",
  "displayName": "ServiceNow",
  "description": "VERIFIED LIVE: ServiceNow ITSM via your logged-in instance (content-script session bridge — no API token). Full read surface over /api/now: a generic table query (any table), single-record lookup, and aggregate stats, plus typed shortcuts for incidents, tasks, changes/change-tasks, problems, requests/RITMs/catalog-tasks, catalog items, CMDB CIs, approvals, knowledge, journal (work notes), attachments, users and groups. The instance UI token (window.g_ck) is read from the page MAIN world and sent as X-UserToken, with the session cookie. Tested live by Claude Code — every endpoint below returned 200. Set your instance subdomain when installing.",
  "iconColor": "bg-green-100 text-green-700",
  "category": "project-management",
  "hosts": [
    "https://*.service-now.com/*"
  ],
  "baseUrl": "https://{instance}.service-now.com",
  "auth": {
    "type": "windowToken",
    "windowVar": "g_ck",
    "header": "X-UserToken"
  },
  "credentialFields": [
    {
      "name": "instance",
      "label": "ServiceNow instance",
      "type": "string",
      "required": true,
      "placeholder": "dev12345",
      "description": "Your instance subdomain — the part before .service-now.com."
    }
  ],
  "tools": [
    {
      "name": "snow_current_user",
      "description": "The currently signed-in ServiceNow user. VERIFIED.",
      "method": "GET",
      "path": "/api/now/ui/user/current_user",
      "responseType": "json"
    },
    {
      "name": "snow_table",
      "description": "Query ANY table by name (incident, change_request, cmdb_ci, sys_user, …). Use sysparm_query for encoded filters. The most flexible tool. VERIFIED.",
      "method": "GET",
      "path": "/api/now/table/{table}",
      "responseType": "json",
      "params": [
        {
          "name": "table",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "sysparm_query",
          "in": "query",
          "type": "string",
          "description": "Encoded query, e.g. active=true^priority=1^ORDERBYDESCsys_updated_on"
        },
        {
          "name": "sysparm_fields",
          "in": "query",
          "type": "string",
          "description": "Comma-separated fields to return."
        },
        {
          "name": "sysparm_display_value",
          "in": "query",
          "type": "string",
          "default": "true"
        },
        {
          "name": "sysparm_limit",
          "in": "query",
          "type": "number",
          "default": 10
        },
        {
          "name": "sysparm_offset",
          "in": "query",
          "type": "number",
          "default": 0
        }
      ]
    },
    {
      "name": "snow_record",
      "description": "Get a single record from any table by sys_id. VERIFIED.",
      "method": "GET",
      "path": "/api/now/table/{table}/{sys_id}",
      "responseType": "json",
      "params": [
        {
          "name": "table",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "sys_id",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "sysparm_display_value",
          "in": "query",
          "type": "string",
          "default": "true"
        }
      ]
    },
    {
      "name": "snow_stats",
      "description": "Aggregate stats for a table (count, optionally grouped). VERIFIED.",
      "method": "GET",
      "path": "/api/now/stats/{table}",
      "responseType": "json",
      "params": [
        {
          "name": "table",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "sysparm_count",
          "in": "query",
          "type": "string",
          "default": "true"
        },
        {
          "name": "sysparm_query",
          "in": "query",
          "type": "string"
        },
        {
          "name": "sysparm_group_by",
          "in": "query",
          "type": "string",
          "description": "Field to group counts by, e.g. state or priority."
        }
      ]
    },
    {
      "name": "snow_incidents",
      "description": "Incidents. Filter with sysparm_query. VERIFIED.",
      "method": "GET",
      "path": "/api/now/table/incident",
      "responseType": "json",
      "params": [
        {
          "name": "sysparm_query",
          "in": "query",
          "type": "string"
        },
        {
          "name": "sysparm_limit",
          "in": "query",
          "type": "number",
          "default": 10
        },
        {
          "name": "sysparm_display_value",
          "in": "query",
          "type": "string",
          "default": "true"
        }
      ]
    },
    {
      "name": "snow_tasks",
      "description": "Tasks (base table for incidents/changes/etc.). VERIFIED.",
      "method": "GET",
      "path": "/api/now/table/task",
      "responseType": "json",
      "params": [
        {
          "name": "sysparm_query",
          "in": "query",
          "type": "string"
        },
        {
          "name": "sysparm_limit",
          "in": "query",
          "type": "number",
          "default": 10
        },
        {
          "name": "sysparm_display_value",
          "in": "query",
          "type": "string",
          "default": "true"
        }
      ]
    },
    {
      "name": "snow_change_requests",
      "description": "Change requests. VERIFIED.",
      "method": "GET",
      "path": "/api/now/table/change_request",
      "responseType": "json",
      "params": [
        {
