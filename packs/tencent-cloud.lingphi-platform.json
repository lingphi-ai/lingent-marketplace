      "name": "tc_account_summary",
      "description": "Your CAM account summary (users, roles, policies, groups). VERIFIED.",
      "method": "POST",
      "path": "",
      "params": [
        {
          "name": "cmd",
          "in": "query",
          "type": "string",
          "required": true,
          "default": "GetAccountSummary"
        },
        {
          "name": "action",
          "in": "query",
          "type": "string",
          "required": true,
          "default": "delegate"
        },
        {
          "name": "serviceType",
          "in": "query",
          "type": "string",
          "required": true,
          "default": "cam"
        },
        {
          "name": "secure",
          "in": "query",
          "type": "string",
          "default": "1"
        },
        {
          "name": "version",
          "in": "query",
          "type": "string",
          "default": "3"
        },
        {
          "name": "csrfCode",
          "in": "query",
          "from": "cookie",
          "cookieName": "skey",
          "transform": "tencentCsrf",
          "required": true,
          "description": "Auto: Tencent console CSRF = djb2(skey cookie). Filled by the session bridge."
        },
        {
          "name": "uin",
          "in": "query",
          "from": "cookie",
          "cookieName": "uin",
          "transform": "digits",
          "required": true,
          "description": "Auto: account uin from the uin cookie (o-prefix stripped)."
        },
        {
          "name": "ownerUin",
          "in": "query",
          "from": "cookie",
          "cookieName": "uin",
          "transform": "digits",
          "required": true,
          "description": "Auto: same as uin."
        },
        {
          "name": "serviceType",
          "in": "body",
          "type": "string",
          "required": true,
          "default": "cam"
        },
        {
          "name": "cmd",
          "in": "body",
          "type": "string",
          "required": true,
          "default": "GetAccountSummary"
        },
        {
          "name": "regionId",
          "in": "body",
          "type": "number",
          "default": 1
        },
        {
          "name": "data",
          "in": "body",
          "type": "object",
          "required": true,
          "default": {
            "Version": "2019-01-16"
          },
          "description": "Action params incl. Version. Add fields per the Tencent Cloud API for this action."
        }
