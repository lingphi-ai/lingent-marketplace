{
  "id": "zhihu-manifest",
  "version": "0.1.0",
  "displayName": "知乎 Zhihu",
  "description": "VERIFIED LIVE: Zhihu data via your logged-in session (session bridge — no token). Your profile, any member's public profile, their answers and followees work cookie-only on the v4 API (search/recommendation feed need x-zse-96 signing — not included). Tested live by Claude Code: me, member profile, answers and followees all returned real data.",
  "iconColor": "bg-blue-100 text-blue-700",
  "category": "social",
  "hosts": [
    "https://www.zhihu.com/*"
  ],
  "baseUrl": "https://www.zhihu.com/api/v4",
  "auth": {
    "type": "cookie"
  },
  "credentialFields": [],
  "tools": [
    {
      "name": "zhihu_me",
      "description": "Your own Zhihu account profile (name, url_token, counts). VERIFIED.",
      "method": "GET",
      "path": "/me",
      "responseType": "json",
      "params": [
        {
          "name": "include",
          "in": "query",
          "type": "string",
          "default": "follower_count,answer_count,articles_count,voteup_count"
        }
      ]
    },
    {
      "name": "zhihu_member",
      "description": "A member's public profile by url_token (e.g. 'suchengqing'). VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}",
      "responseType": "json",
      "params": [
        {
          "name": "urlToken",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "include",
          "in": "query",
          "type": "string",
          "default": "follower_count,answer_count,articles_count,voteup_count,headline"
        }
      ]
    },
    {
      "name": "zhihu_member_answers",
      "description": "A member's answers by url_token. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/answers",
      "responseType": "json",
      "params": [
        {
          "name": "urlToken",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 10
        },
        {
          "name": "offset",
          "in": "query",
          "type": "number",
          "default": 0
        }
      ]
    },
    {
      "name": "zhihu_member_followees",
      "description": "Who a member follows, by url_token. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/followees",
      "responseType": "json",
      "params": [
        {
          "name": "urlToken",
          "in": "path",
          "type": "string",
          "required": true
        },
        {
          "name": "limit",
          "in": "query",
          "type": "number",
          "default": 10
        },
        {
          "name": "offset",
          "in": "query",
          "type": "number",
          "default": 0
        }
      ]
    }
  ],
  "transport": {
    "preferred": "cs"
  },
  "retry": {
    "maxAttempts": 3,
    "respectRetryAfter": true
  },
  "timeoutMs": 30000
}
