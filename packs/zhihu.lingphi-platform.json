{
  "id": "zhihu-manifest",
  "version": "0.2.0",
  "displayName": "知乎 Zhihu",
  "description": "VERIFIED LIVE: Zhihu via your logged-in session (session bridge — no token). A full read surface over the v4 API: your own profile, plus any member's profile, answers, articles, questions, followees, followers, favlists (collections) and pins — all cookie-only. Tested live by Claude Code against a logged-in session; every endpoint below returned 200. (Search/recommendation feed need x-zse-96 signing — not included.)",
  "iconColor": "bg-blue-100 text-blue-700",
  "category": "social",
  "hosts": [
    "https://www.zhihu.com/*"
  ],
  "baseUrl": "https://www.zhihu.com/api/v4",
  "auth": {
    "type": "cookie"
  },
  "credentialFields": [],
  "tools": [
    {
      "name": "zhihu_me",
      "description": "Your own Zhihu account profile (name, url_token, counts). VERIFIED.",
      "method": "GET",
      "path": "/me",
      "responseType": "json",
      "params": [ { "name": "include", "in": "query", "type": "string", "default": "follower_count,answer_count,articles_count,voteup_count" } ]
    },
    {
      "name": "zhihu_member",
      "description": "A member's public profile by url_token (e.g. 'suchengqing'). VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "include", "in": "query", "type": "string", "default": "follower_count,answer_count,articles_count,voteup_count,headline,description" }
      ]
    },
    {
      "name": "zhihu_member_answers",
      "description": "A member's answers by url_token. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/answers",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    },
    {
      "name": "zhihu_member_articles",
      "description": "A member's published articles by url_token. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/articles",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    },
    {
      "name": "zhihu_member_questions",
      "description": "Questions asked by a member. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/questions",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    },
    {
      "name": "zhihu_member_pins",
      "description": "A member's pins (想法 / short posts). VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/pins",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    },
    {
      "name": "zhihu_member_favlists",
      "description": "A member's collections (收藏夹). VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/favlists",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    },
    {
      "name": "zhihu_member_followees",
      "description": "Who a member follows, by url_token. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/followees",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    },
    {
      "name": "zhihu_member_followers",
      "description": "A member's followers, by url_token. VERIFIED.",
      "method": "GET",
      "path": "/members/{urlToken}/followers",
      "responseType": "json",
      "params": [
        { "name": "urlToken", "in": "path", "type": "string", "required": true },
        { "name": "limit", "in": "query", "type": "number", "default": 10 },
        { "name": "offset", "in": "query", "type": "number", "default": 0 }
      ]
    }
  ],
  "transport": { "preferred": "cs" },
  "retry": { "maxAttempts": 3, "respectRetryAfter": true },
  "timeoutMs": 30000
}
